{
  "version": 2,
  "builds": [
    { "src": "api/chat.py",  "use": "@vercel/python" },
    { "src": "api/daily.py", "use": "@vercel/python" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",       "dest": "/api/chat.py"  },
    { "src": "/api/daily",      "dest": "/api/daily.py" },
    { "src": "/questions.json", "dest": "/public/questions.json" },
    { "src": "/(.*)",           "dest": "/public/$1"    }
  ]
}
